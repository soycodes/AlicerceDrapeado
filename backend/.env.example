# ─── Servidor ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://www.construtoraedifica.com.br

# ─── Resend ────────────────────────────────────────
# 1. Crie conta gratuita em https://resend.com
# 2. Vá em API Keys → Create API Key
# 3. Cole a chave abaixo (começa com "re_")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Destinatários ─────────────────────────────────
# E-mail que RECEBE as mensagens do formulário
MAIL_TO=contato@construtoraedifica.com.br

# Remetente — deve ser de um domínio verificado no Resend.
# Em testes pode usar: onboarding@resend.dev
MAIL_FROM=Edifica Construtora <noreply@construtoraedifica.com.br>

# ─── Rate limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5
